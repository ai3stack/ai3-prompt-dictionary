{
  "name": "@ai3stack/prompts-mcp",
  "version": "0.2.0",
  "description": "MCP server exposing 930+ structured, expert-curated English AI prompts from the AI³ Prompt Dictionary. Plug into Claude, ChatGPT, Gemini, Copilot, Cursor, Cline, and any MCP-capable AI client.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai3-prompts-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.map"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const{chmodSync}=require('fs');try{chmodSync('dist/index.js',0o755)}catch{}\"",
    "dev": "tsx src/index.ts",
    "sync-data": "tsx scripts/sync-data.ts",
    "inspect": "npx -y @modelcontextprotocol/inspector node dist/index.js",
    "smoke-test": "tsx scripts/smoke-test.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "node -e \"console.log('[prepublishOnly] using committed data/*.json as source of truth; run \\'npm run sync-data\\' manually against upstream content before publishing if data changed')\" && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "prompts",
    "prompt-library",
    "ai",
    "claude",
    "claude-desktop",
    "chatgpt",
    "cursor",
    "cline",
    "ai3",
    "prompt-engineering"
  ],
  "license": "MIT",
  "author": "AI³ Prompt Dictionary contributors",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://ai3stack.com",
  "bugs": {
    "email": "ai3@ai3stack.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ai3stack/ai-prompt-dictionary.git",
    "directory": "mcp-server"
  }
}
